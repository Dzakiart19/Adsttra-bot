modules = ["nodejs-20", "bash", "python-base-3.13"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
PUPPETEER_CACHE_DIR = ".puppeteer_cache"
BEHAVIOR_INTENSITY = "medium"
BOT_ROLE = "both"
DEFAULT_URL = "https://simpanin.web.app"
HEADLESS = "true"
HUMAN_BEHAVIOR = "true"
LOG_LEVEL = "info"
MATCH_GEOLOCATION = "true"
MAX_SESSIONS = "5"
NODE_ENV = "production"
ORGANIC_SEARCH = "false"
PERSISTENT_SESSIONS = "false"
PROXY_PASS = ""
PROXY_PORT = ""
PROXY_URL = ""
PROXY_USER = ""
REDIS_URL = "redis://127.0.0.1:6379"
REFERRER_POOL = "https://www.google.com,https://www.facebook.com,https://t.co,https://l.instagram.com,https://www.youtube.com"
SEARCH_KEYWORDS = ""
SESSIONS_DATA_DIR = "./sessions"
SESSION_TIME = "30"
USE_FREE_PROXIES = "true"
LOOP_COOLDOWN_SEC = "0"
LOOP_FOREVER = "true"
PROXY_VALIDATE_CONCURRENCY = "40"
SEARCH_ENGINE = "google"
URL = "https://dramacina--dzeckart.replit.app"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Veneno Traffic Bot"

[[workflows.workflow]]
name = "Veneno Traffic Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start.sh"]
build = ["bash", "-c", "npm install && npm run build && rm -f proxy_cache.json uptime_stats.json && rm -rf .puppeteer_cache/chrome-headless-shell && PUPPETEER_CACHE_DIR=.puppeteer_cache npx puppeteer browsers install chrome-headless-shell && bash bundle_libs.sh"]

[[ports]]
localPort = 3000
externalPort = 80
