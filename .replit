modules = ["nodejs-20", "bash", "python-base-3.13"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
PUPPETEER_CACHE_DIR = ".puppeteer_cache"
BEHAVIOR_INTENSITY = "medium"
BOT_ROLE = "both"
DEFAULT_URL = "https://www.effectivecpmnetwork.com/dknrw1cb8?key=5fa604a5dd5abb73116ecb3422721daa"
HEADLESS = "true"
HUMAN_BEHAVIOR = "true"
LOG_LEVEL = "info"
MATCH_GEOLOCATION = "true"
MAX_SESSIONS = "5"
NODE_ENV = "production"
ORGANIC_SEARCH = "false"
PERSISTENT_SESSIONS = "false"
PROXY_PASS = ""
PROXY_PORT = ""
PROXY_URL = ""
PROXY_USER = ""
REDIS_URL = "redis://127.0.0.1:6379"
REFERRER_POOL = ""
SEARCH_KEYWORDS = ""
SESSIONS_DATA_DIR = "./sessions"
SESSION_TIME = "10"
USE_FREE_PROXIES = "true"
LOOP_COOLDOWN_SEC = "0"
LOOP_FOREVER = "true"
PROXY_VALIDATE_CONCURRENCY = "40"
SEARCH_ENGINE = "google"
WEBSHARE_MAX_FAILURES = "10"
WEBSHARE_PROXY_LIST = "31.59.20.176:6754:ntavlolm:s7qtewzztsrs,31.56.127.193:7684:ntavlolm:s7qtewzztsrs,45.38.107.97:6014:ntavlolm:s7qtewzztsrs,198.105.121.200:6462:ntavlolm:s7qtewzztsrs,64.137.96.74:6641:ntavlolm:s7qtewzztsrs,198.23.243.226:6361:ntavlolm:s7qtewzztsrs,142.111.67.146:5611:ntavlolm:s7qtewzztsrs"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Veneno Traffic Bot"

[[workflows.workflow]]
name = "Veneno Traffic Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start.sh"]
build = ["bash", "-c", "npm install && npm run build && rm -f proxy_cache.json uptime_stats.json && rm -rf .puppeteer_cache/chrome-headless-shell && PUPPETEER_CACHE_DIR=.puppeteer_cache npx puppeteer browsers install chrome-headless-shell && python3 -c \"import re\ntry:\n  c=open('.cache/replit/nix/env.json').read()\n  m=re.search(r'\\\"REPLIT_LD_LIBRARY_PATH\\\":\\\"([^\\\"]+)\\\"',c)\n  ld=m.group(1) if m else ''\n  gbm=sorted(set(re.findall(r'/nix/store/[a-z0-9]+-mesa-libgbm[^\\\":/\\\\s]*',c)))\n  gbm_lib=gbm[-1]+'/lib' if gbm else ''\n  open('.nix_env','w').write(ld+'|'+gbm_lib)\n  print('[build] .nix_env saved GBM='+gbm_lib)\nexcept Exception as e:\n  print('[build] WARNING .nix_env gagal:',e)\n\""]

[[ports]]
localPort = 3000
externalPort = 80
