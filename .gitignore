# Dependency directories
node_modules/

# Build outputs
dist/

# Session data (Persistent browser profiles)
sessions/

# Configuration
.env
.env.test

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# System files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Lock files (Currently ignored, but can be removed if strictly wanted)
package-lock.json

# Runtime cache files — dibuat ulang otomatis saat bot jalan
proxy_cache.json
uptime_stats.json

# Chrome binary — terlalu besar untuk GitHub (180MB+), auto-download oleh start.sh
# Metadata folder boleh di-commit, tapi binary-nya tidak
.puppeteer_cache/chrome-headless-shell/

# Uploaded assets / screenshots (tidak perlu di-commit)
attached_assets/

# Replit internal cache
.cache/
